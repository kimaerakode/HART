---
import SideBarLayout from "../layouts/SideBarLayout.astro";
import FaqBox from "../components/atoms/FaqBox.astro";
---

<SideBarLayout title="Contact" color="charcoal">
  <section id="contact">

    <div class="box-wrapper">
      <FaqBox type="orders" />
      <FaqBox type="products" />
    </div>
  </section>
</SideBarLayout>

<style>
  .title-wrapper {
    height: fit-content;
    width: 100%;
    margin-bottom: var(--space-m);
  }
  .box-wrapper {
    min-height: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-l);
    height: 100%;
  }
</style>
