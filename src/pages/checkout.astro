---
import SideBarLayout from "../layouts/SideBarLayout.astro";
import CheckoutSelection from "../components/molecules/checkout/CheckoutSelection.jsx";
import CheckoutForm from "../components/molecules/checkout/CheckoutForm.astro";
import CheckoutSubmit from "../components/molecules/checkout/CheckoutSubmit.astro";
import GiftCard from "../components/atoms/GiftCard.astro";
import CartItems from "../components/molecules/CartItems.jsx";
import CartTotal from "../components/atoms/CartTotal.jsx";
import CheckoutBar from "../components/molecules/checkout/CheckoutBar.astro";
---

<SideBarLayout title="Pre-Order" menuVariant="checkout" color="charcoal">
  <section id="checkout">
    <div class="title-wrapper page-title">
      <h1>Pre-order</h1>
    </div>
    <div class="content">
      <div class="selection-wrapper">
        <CheckoutSelection client:load />
      </div>
      <GiftCard placement="mobile" />

      <div class="form-wrapper">
        <div class="title-wrapper">
          <h2>Checkout</h2>
        </div>

        <CheckoutForm />

        <GiftCard placement="desktop" />
        <CheckoutSubmit placement="desktop" />
      </div>
      <div class="cart-wrapper">
        <div class="title-wrapper"><h2>Cart Items</h2></div>
        <CartItems buttonColor="charcoal" buttonTone="cream" client:load />
        <CartTotal placement="desktop" client:load />
      </div>
    </div>
  </section>
  <CheckoutBar />
</SideBarLayout>
<style>
  @media screen and (max-width: 1023px) {
    section#checkout {
      gap: var(--space-s);
      padding-top: var(--space-s);
    }
  }
  section#checkout {
    display: flex;
    flex-direction: column;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .form-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }
  @media screen and (min-width: 1024px) {
    .page-title {
      display: none;
    }
    .selection-wrapper {
      display: none;
    }
    .content {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-xl);
      width: 100%;
      height: 100%;
    }

    .content > * {
      height: 100%;
    }

    .form-wrapper {
      width: 100%;
      height: 100%;
      min-height: 0;
    }

    .form-wrapper :global(.giftcard--desktop) {
      margin-block: auto;
    }

    .cart-wrapper {
      display: grid;
      grid-template-rows: auto minmax(0, 1fr) auto;
      height: 100%;
      min-height: 0;
      padding-block-end: var(--space-s);
    }
  }
</style>
