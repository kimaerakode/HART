---
import Layout from "../layouts/Layout.astro";
import TextBox from "../components/atoms/TextBox.astro";

const aboutHart = [
  {
    title: "our story",
    description:
      "Hart Bakery was founded in 2018 and emerged from a partnership between Richard Hart, René Redzepi, and the partners behind Restaurant noma. Richard Hart, formerly the Head Baker at Tartine in San Francisco, aspired to produce the finest bread and pastries at Hart Bakery. ",
  },

  {
    title: "our philosophy",
    description:
      "At Hart Bakery, our philosophy is one of constant evolution. We compete only with ourselves, striving each day to surpass what we achieved the previous year, the previous day, the previous bake.",
  },

  {
    title: "our baking approach",
    description:
      "We are not your traditional Danish bakery. Our bakers bring a playful levity to classic recipes, creating a signature style that sets us apart. Our offerings showcase high-quality ingredients, expertly crafted by our team of skilled bakers. We embrace the seasons, allowing the continual renewal of the natural world to inspire our creations.",
  },
];
---

<Layout
  color="cream"
  headerVariant="primary"
  headerBorderless={true}
  footerVariant="primary"
  ><main>
    <video
      src="/assets/video/promo-video.mp4"
      class="video-bg"
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"></video>
    <section id="about">
      <div class="wrapper move-in">
        {
          aboutHart.map((content) => (
            <TextBox title={content.title} description={content.description} />
          ))
        }
      </div>
    </section>
  </main>

  <style>
    :global(body) {
      background-color: black;
    }
    section#about {
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: row;
      justify-content: center;
      align-items: center;
      margin-block-start: var(--header-height);
      padding-block: var(--space-l);
      padding-inline: var(--space-s);

      margin-inline: 0;
    }
    .video-bg {
      width: 100%;
      height: 100%;
      object-position: center 30%;
      position: absolute;
      inset: 0;
      object-fit: cover;
      position: fixed;
      transition: opacity var(--slowly);
      opacity: 70%;
    }

    .wrapper {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      align-self: center;
      gap: var(--space-l);
      transform: translateY(12px);
      padding-block-end: var(--space-l);
    }

    .wrapper :global(.box:hover) .video-bg {
      opacity: 50%;
    }

    @media screen and (min-width: 1024px) {
      main {
        margin: 0;
        padding: 0;
      }
      section#about {
        height: calc(100svh - (var(--header-height) + var(--footer-height)));
        padding-block: 0;
        margin-inline: 0;
        padding-inline: var(--space-m);
        justify-content: start;
      }
      .wrapper {
        flex-direction: row;
        padding-block-end: 0;
      }

      .wrapper :global(.box) {
        transition: transform var(--slowly);
      }

      .wrapper :global(.box:hover) {
        transform: scale(1.05);
      }
    }
  </style>
</Layout>
