---
import SideBarLayout from "../layouts/SideBarLayout.astro";
import FilterBar from "../components/molecules/FilterBar.astro";
import LocationCard from "../components/organisms/LocationCard.astro";
import ArrowBar from "../components/molecules/ArrowBar.astro";
import { shops } from "../data/shopsData";
---

<SideBarLayout title="Shops" color="charcoal">
  <section id="shops" class="no-scrollbar">
    <div class="filter-wrapper">
      <FilterBar variant="shops" />
    </div>
    <div class="card-wrapper move-in">
      {
        shops.map((shop) => (
          <LocationCard
            title={shop.title}
            area={shop.area}
            adress={`${shop.street}\n${shop.town}`}
            openHours={`${shop.openHours1}\n${shop.openHours2}`}
            imgSrc={shop.imgSrc}
          />
        ))
      }
    </div>
    <ArrowBar />
  </section>
</SideBarLayout>

<style>
  section#shops {
    overflow-x: hidden;
    padding-block-end: var(--space-l);
  }

  .filter-wrapper {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
  }

  .card-wrapper {
    display: grid;
    gap: var(--space-l);
    height: fit-content;
    overflow-x: hidden;
  }

  @media screen and (min-width: 620px) {
    .filter-wrapper {
      display: none;
    }
    .card-wrapper {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    section#shops {
      padding-inline: 0;
      margin-inline-end: var(--space-m);
      padding-block-end: 0;
      max-width: 100%;
       border-right: var(--border) var(--color-charcoal);
    }

    .card-wrapper {
      grid-template-columns: repeat(2, 1fr);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      /* scroll-padding-inline-end: var(--space-m); */
      gap: calc(var(--space-l) - var(--space-m));
      overflow-y: hidden;
      white-space: nowrap;
      height: 100%;
      width: 100%;
     
    }
  }
</style>

<script>
  // @ts-nocheck
  const setupShopFilters = () => {
    const section = document.querySelector("#shops");

    if (!(section instanceof HTMLElement)) return;

    if (section.dataset.filtersInitialized === "true") return;
    section.dataset.filtersInitialized = "true";

    const buttons = Array.from(
      document.querySelectorAll('.filter-btn[data-filter]'),
    );
    const cards = Array.from(section.querySelectorAll(".card[data-area]"));

    if (!buttons.length || !cards.length) return;

    const normalize = (value) => value.trim().toLowerCase();

    const setActiveButton = (activeFilter) => {
      buttons.forEach((button) => {
        const buttonFilter = normalize(
          button.dataset.filter || button.textContent || "",
        );
        const isSelected = Boolean(activeFilter) && buttonFilter === activeFilter;

        button.classList.toggle("selected", isSelected);
        button.setAttribute("aria-pressed", String(isSelected));
      });
    };

    const renderCards = (filterValue) => {
      const activeFilter = normalize(filterValue || "");

      cards.forEach((card) => {
        const cardArea = normalize(card.dataset.area || "");
        const shouldShow = !activeFilter || cardArea === activeFilter;

        card.hidden = !shouldShow;
      });

      setActiveButton(activeFilter);
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const buttonFilter = normalize(
          button.dataset.filter || button.textContent || "",
        );
        const nextFilter = button.classList.contains("selected")
          ? ""
          : buttonFilter;

        renderCards(nextFilter);
      });
    });

    renderCards("");
  };

  const initializeShopFilters = () => setupShopFilters();

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeShopFilters, {
      once: true,
    });
  } else {
    initializeShopFilters();
  }

  document.addEventListener("astro:page-load", initializeShopFilters);
  document.addEventListener("astro:after-swap", initializeShopFilters);
</script>
