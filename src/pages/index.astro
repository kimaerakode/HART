---
import Layout from "../layouts/Layout.astro";
---

<Layout
  color="cream"
  headerVariant="secondary"
  footerVariant="secondary"
  menuVariant="main"
>
  <section class="hero">
    <video
      class="video-bg"
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
      poster="/assets/img/hero-video-still.webp"
    >
      <source
        src="/assets/video/skg_mobile_comp.mp4"
        media="(max-width: 1023px)"
      />
      <source
        src="/assets/video/skg_mobile_comp.mp4"
        media="(prefers-reduced-data: reduce)"
      />
      <source src="/assets/video/hero-video.mp4" media="(min-width: 1024px)" />
    </video>
  </section>

  <style>
    .hero {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100dvh;
      overflow: hidden;
      margin-inline: 0;
      padding-inline: 0;
      isolation: isolate;
    }

    .video-bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      z-index: -1;
      transition: object-position 4.5s ease;
    }

    @media screen and (min-width: 1024px) {
      .video-bg {
        object-position: center 34%;
      }
    }
  </style>
</Layout>
