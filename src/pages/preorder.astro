---
import SideBarLayout from "../layouts/SideBarLayout.astro";
import PickupBar from "../components/organisms/PickupBar.astro";
import PopoverPreorder from "../components/organisms/Popover-Preorder.astro";
import FilterBar from "../components/molecules/FilterBar.astro";
import ProductCard from "../components/organisms/ProductCard.astro";
import ProductModalController from "../components/ui/ProductModalController.jsx";
import products from "../data/products.js";
---

<SideBarLayout
  title="Pre-Order"
  color="charcoal"
  menuVariant="preorder"
  mainClass="scroll"
  sidebarClass="add-margin"
>
  <PopoverPreorder />
  <PickupBar />

  <section id="preorder" class="no-scrollbar">
    <div class="filter-wrapper">
      <FilterBar variant="products" />
    </div>
    <div class="title-wrapper">
      <h2>Select items</h2>
    </div>
    <div class="card-wrapper move-up">
      {
        products.map((product) => (
          <ProductCard
            title={product.title}
            price={product.price}
            imgSrc={`/assets/img/products/${product.img}`}
            time={product.time}
            favorite={product.favorite}
            category={product.category}
            description={product.description}
            allergens={product.allergens}
          />
        ))
      }
    </div>
    <ProductModalController client:load />
  </section>
</SideBarLayout>

<style>
  @media screen and (max-width: 480px) {
    .card-wrapper {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }
  }
  @media screen and (min-width: 480px) {
    .card-wrapper {
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    }
  }

  section#preorder {
    display: flex;
    flex-direction: column;
    justify-content: start;
    overflow-y: auto;
    height: 100%;
    padding-bottom: var(--space-l);
  }
  .title-wrapper {
    display: none;
  }

  .filter-wrapper {
    overflow-x: auto;
  }

  .card-wrapper {
    display: grid;
    grid-auto-flow: row;
    grid-auto-rows: 1fr;
    position: relative;
    column-gap: var(--space-m);
    row-gap: var(--space-s);
    width: 100%;
  }

  @media screen and (min-width: 1024px) {
    section#preorder {
      padding-block: var(--space-m);
      row-gap: var(--space-xs-s);
    }

    .filter-wrapper {
      overflow-x: visible;
      width: 100%;
    }

    .filter-wrapper .wrapper {
      width: 100%;
    }

    .filter-wrapper .filter-bar {
      flex-wrap: wrap;
    }

    .card-wrapper {
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      column-gap: var(--space-l);
      row-gap: var(--space-s);
      padding-block-start: var(--space-s);
      padding-block-end: var(--space-xl);
    }
    .title-wrapper {
      display: block;
      order: -1;
    }
  }
</style>

<script>
  // @ts-nocheck
  const setupPreorderFilters = () => {
    const section = document.querySelector("#preorder");

    if (!(section instanceof HTMLElement)) return;

    const buttons = Array.from(
      section.querySelectorAll(".filter-btn[data-filter]"),
    );
    const wrapper = section.querySelector(".card-wrapper");

    if (!(wrapper instanceof HTMLElement) || !buttons.length) return;

    const originalCards = Array.from(wrapper.children).map((card) =>
      card.cloneNode(true),
    );

    // use CSS `move-up` animation by toggling the class on swap

    const normalize = (value) => value.trim().toLowerCase();

    const setActiveButton = (activeButton) => {
      buttons.forEach((button) => {
        button.classList.toggle("selected", button === activeButton);
      });
    };

    const renderFilteredCards = (filterValue) => {
      const normalizedFilter = normalize(filterValue);

      const matchingCards = !normalizedFilter
        ? originalCards
        : originalCards.filter((card) => {
            const category = normalize(card.dataset.category || "");
            const isFavorite = card.dataset.favorite === "true";

            return normalizedFilter === "favorites"
              ? isFavorite
              : category === normalizedFilter;
          });

      // Replace children and trigger the CSS `move-up` animation by toggling the class
      wrapper.classList.remove("move-up");
      wrapper.replaceChildren(
        ...matchingCards.map((card) => card.cloneNode(true)),
      );
      // Force layout then re-add class to retrigger animation
      // eslint-disable-next-line no-unused-expressions
      wrapper.offsetWidth;
      wrapper.classList.add("move-up");
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        renderFilteredCards(button.dataset.filter || button.textContent || "");
        setActiveButton(button);
      });
    });

    renderFilteredCards("");
  };

  const initializePreorderFilters = () => setupPreorderFilters();

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePreorderFilters, {
      once: true,
    });
  } else {
    initializePreorderFilters();
  }

  document.addEventListener("astro:page-load", initializePreorderFilters);
  document.addEventListener("astro:after-swap", initializePreorderFilters);
</script>

<script>
  // @ts-nocheck
  // Simple delegated handler that opens the product modal via CustomEvent
  const setupModalTrigger = () => {
    const root = document.querySelector("#preorder");
    if (!root) return;

    /** @param {HTMLElement} card */
    function openProductModal(card) {
      const ds = /** @type {any} */ (card).dataset || {};

      const detail = {
        title: ds.title,
        price: ds.price,
        imgSrc: ds.img,
        time: ds.time,
        description: ds.description,
        allergens: ds.allergens,
      };

      window.__hartPendingProductModal = detail;
      window.dispatchEvent(new CustomEvent("open-product", { detail }));
    }

    root.addEventListener("click", (e) => {
      const target = e.target;
      const maybe = target instanceof Element ? target.closest(".card") : null;
      const card = maybe instanceof HTMLElement ? maybe : null;
      if (!card) return;
      openProductModal(card);
    });

    // keyboard activation for accessibility: Enter or Space opens product
    root.addEventListener("keydown", (e) => {
      if (!(e instanceof KeyboardEvent)) return;
      if (e.key !== "Enter" && e.key !== " ") return;
      const target = e.target;
      const maybe = target instanceof Element ? target.closest(".card") : null;
      const card = maybe instanceof HTMLElement ? maybe : null;
      if (!card) return;
      // prevent page scroll on Space
      if (e.key === " ") e.preventDefault();
      openProductModal(card);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupModalTrigger, {
      once: true,
    });
  } else {
    setupModalTrigger();
  }

  document.addEventListener("astro:page-load", setupModalTrigger);
  document.addEventListener("astro:after-swap", setupModalTrigger);
</script>
