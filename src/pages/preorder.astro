---
import SideBarLayout from "../layouts/SideBarLayout.astro";
import PickupBar from "../components/organisms/PickupBar.astro";
import FilterBar from "../components/molecules/FilterBar.astro";
import ProductCard from "../components/organisms/ProductCard.astro";
import products from "../data/products.js";
---

<SideBarLayout
  title="Pre-Order"
  color="charcoal"
  mainClass="scroll"
  sidebarClass="add-margin"
>
  <PickupBar />

  <section id="preorder" class="no-scrollbar">
    <div class="filter-wrapper">
      <FilterBar variant="products" />
    </div>
    <div class="title-wrapper">
      <h2>Select items</h2>
    </div>
    <div class="card-wrapper move-up">
      {
        products.map((product) => (
          <ProductCard
            title={product.title}
            price={product.price}
            imgSrc={`/assets/img/products/${product.img}`}
            favorite={product.favorite}
            category={product.category}
          />
        ))
      }
    </div>
  </section>
</SideBarLayout>

<style>
  section#preorder {
    display: flex;
    flex-direction: column;
    justify-content: start;
    overflow-y: auto;
    height: 100%;
  }
  .title-wrapper {
    display: none;
  }

  .card-wrapper {
    display: grid;
    grid-auto-flow: row;
    grid-auto-rows: 1fr;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    position: relative;
    column-gap: var(--space-m);
    row-gap: var(--space-s);
    width: 100%;
    padding-block-start: var(--space-s);
  }

  @media screen and (min-width: 1024px) {
    section#preorder {
      padding-block-start: var(--space-m);
      row-gap: var(--space-xs-s);
      padding-bottom: var(--space-xl);
    }

    .card-wrapper {
      column-gap: var(--space-l);
      row-gap: var(--space-s);
      padding-block: var(--space-s);
    }
    .title-wrapper {
      display: block;
      order: -1;
    }
  }
  @media screen and (min-width: 1900px) {
    .card-wrapper {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }
  }
</style>

<script>
  // @ts-nocheck
  const setupPreorderFilters = () => {
    const section = document.querySelector("#preorder");

    if (!(section instanceof HTMLElement)) return;

    const buttons = Array.from(
      section.querySelectorAll(".filter-btn[data-filter]"),
    );
    const wrapper = section.querySelector(".card-wrapper");

    if (!(wrapper instanceof HTMLElement) || !buttons.length) return;

    const originalCards = Array.from(wrapper.children).map((card) =>
      card.cloneNode(true),
    );

    // use CSS `move-up` animation by toggling the class on swap

    const normalize = (value) => value.trim().toLowerCase();

    const setActiveButton = (activeButton) => {
      buttons.forEach((button) => {
        button.classList.toggle("selected", button === activeButton);
      });
    };

    const renderFilteredCards = (filterValue) => {
      const normalizedFilter = normalize(filterValue);

      const matchingCards = !normalizedFilter
        ? originalCards
        : originalCards.filter((card) => {
            const category = normalize(card.dataset.category || "");
            const isFavorite = card.dataset.favorite === "true";

            return normalizedFilter === "favorites"
              ? isFavorite
              : category === normalizedFilter;
          });

      // Replace children and trigger the CSS `move-up` animation by toggling the class
      wrapper.classList.remove("move-up");
      wrapper.replaceChildren(
        ...matchingCards.map((card) => card.cloneNode(true)),
      );
      // Force layout then re-add class to retrigger animation
      // eslint-disable-next-line no-unused-expressions
      wrapper.offsetWidth;
      wrapper.classList.add("move-up");
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        renderFilteredCards(button.dataset.filter || button.textContent || "");
        setActiveButton(button);
      });
    });

    renderFilteredCards("");
  };

  const initializePreorderFilters = () => setupPreorderFilters();

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializePreorderFilters, {
      once: true,
    });
  } else {
    initializePreorderFilters();
  }

  document.addEventListener("astro:page-load", initializePreorderFilters);
  document.addEventListener("astro:after-swap", initializePreorderFilters);
</script>
