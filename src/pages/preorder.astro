---

<SideBarLayout
  title="Pre-Order"
  color="charcoal"
  mainClass="scroll"
  sidebarClass="add-margin"
>
  <PickupBar />

  <section id="preorder" class="no-scrollbar">
    <div class="filter-wrapper">
      <FilterBar variant="products" />
    </div>
    <div class="title-wrapper">
      <h2>Select items</h2>
    </div>
    <div class="scroller">
      <!-- <div class="wrapper move-in"> -->
      {
        products.map((product) => (
          <ProductCard
            title={product.title}
            price={product.price}
            imgSrc={`/assets/img/products/${product.img}`}
            favorite={product.favorite}
            category={product.category}
          />
        ))
      }
      <!-- </div> -->
    </div>
  </section>
</SideBarLayout>

<style>
  section#preorder {
    display: flex;
    flex-direction: column;
    justify-content: start;
    overflow-y: hidden;
    height: 100%;
  }
  .title-wrapper {
    display: none;
  }


  @media screen and (max-width: 1023px) {
  .scroller {
    container: products / inline-size;
    display: grid;
    grid-auto-flow: row;
    grid-auto-rows: 1fr;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    position: relative;
    column-gap: var(--space-m);
    row-gap: var(--space-s);
    width: 100%;
    padding-block-start: var(--space-s);
  }
}

  /* @media screen and (max-width: 1024px) {
  .scroller {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));

    gap: var(--space-m);
    padding-top: var(--space-s);
  }
} */

  @media screen and (min-width: 1024px) {
    section#preorder {
      display: flex;
      flex-direction: column;
      position: relative;
      padding-block-start: var(--space-m);
      row-gap: var(--space-xs-s);
      margin-inline: 0;
      overflow-y: hidden;
      width: 100%;
      grid-area: main;
    }

    .scroller {
      container: products / inline-size;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: 1fr;
      grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
      position: relative;
      overflow-x: auto;
      overflow-y: hidden;
      column-gap: var(--space-l);
      row-gap: var(--space-s);
      width: 100%;
      padding-inline: var(--space-m);
      padding-block: var(--space-s);
    }
    .title-wrapper {
      display: block;
      order: -1;
      margin-inline: var(--space-m);
    }

    .filter-wrapper {
      margin-inline: var(--space-m);
    }
    .wrapper {
      /* grid-auto-columns: minmax(14.1vw, 1fr); */

      /* grid-template-columns: none; */
      /* grid-template-rows: repeat(2, 1fr); */

      column-gap: var(--space-l);
      row-gap: var(--space-xs);
      width: fit-content;
      height: 100%;
      align-self: start;
      padding-top: var(--space-s);
      padding-inline: var(--space-m);
    }
  }

  @media screen and (min-width: 1480px) and (min-height: 900px) {
    .scroller {
      grid-template-rows: repeat(3, minmax(0, 1fr));
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  let destroyHorizontalScroll: (() => void) | undefined;

  const setupHorizontalScroll = () => {
    destroyHorizontalScroll?.();

    const scroller = document.querySelector<HTMLElement>(".scroller");
    if (!scroller) return;

    // Keep small screens on the default vertical flow.
    if (window.matchMedia("(max-width: 1023px)").matches) {
      return;
    }

    const onWheel = (event: Event) => {
      const wheel = event as WheelEvent;
      if (Math.abs(wheel.deltaY) <= Math.abs(wheel.deltaX)) return;

      const maxScrollLeft = scroller.scrollWidth - scroller.clientWidth;
      if (maxScrollLeft <= 0) return;

      const next = scroller.scrollLeft + wheel.deltaY;
      const clamped = Math.max(0, Math.min(maxScrollLeft, next));
      if (clamped === scroller.scrollLeft) return;

      event.preventDefault();
      gsap.to(scroller, {
        scrollLeft: clamped,
        duration: 0.1,
        ease: "power2.out",
        overwrite: "auto",
      });
    };

    scroller.addEventListener("wheel", onWheel, { passive: false });

    destroyHorizontalScroll = () => {
      scroller.removeEventListener("wheel", onWheel);
      gsap.killTweensOf(scroller);
    };
  };

  const initPreorderHorizontalScroll = () => setupHorizontalScroll();

  document.addEventListener("astro:page-load", initPreorderHorizontalScroll);
  document.addEventListener("astro:after-swap", initPreorderHorizontalScroll);

  if (document.readyState === "loading") {
    document.addEventListener(
      "DOMContentLoaded",
      initPreorderHorizontalScroll,
      {
        once: true,
      },
    );
  } else {
    initPreorderHorizontalScroll();
  }
</script>
