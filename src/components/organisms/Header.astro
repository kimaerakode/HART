---
import { fade } from "astro:transitions";
import NavMenu from "../molecules/NavMenu.astro";

const {
  color = "cream",
  variant = "primary",
  borderless = false,
} = Astro.props;
const isSecondary = variant === "secondary";
const navMenuDirection = isSecondary ? "column" : "row";

const logoSrc =
  color === "charcoal"
    ? "/assets/brand/hart-logo-primary-charcoal.svg"
    : "/assets/brand/hart-logo-primary-cream.svg";
---

<header class={!isSecondary && !borderless ? "header--primary" : ""}>
  <nav>
    <div
      class="header"
      transition:name="header-row"
      transition:animate={fade({ duration: "0.2s" })}
    >
      <button class="mobile-toggle">
        <img src={`/assets/icons/menu-${color}.svg`} alt="" />
      </button>

      <a href="/">
        <img
          class="logo"
          width="100"
          height="39"
          src={logoSrc}
          alt="HART logo"
        /></a
      >
      {
        isSecondary ? (
          <button
            class="cart-icon-wrapper"
            type="button"
            aria-label="Open cart"
          >
            <p class="cart-count text-xs" data-cart-count>
              0
            </p>
            <picture>
              <source
                media="(max-width: 1024px)"
                srcset="/assets/icons/cart-small-cream.svg"
              />
              <img
                class="cart-icon"
                src="/assets/icons/cart-md-cream.svg"
                alt="Cart icon"
              />
            </picture>
          </button>
        ) : (
          <div class="header-actions">
            <div class="header-menu-wrapper">
              <NavMenu direction={navMenuDirection} />
            </div>
            <button
              class="cart-icon-wrapper"
              type="button"
              aria-label="Open cart"
            >
              <p class="cart-count text-xs" data-cart-count>
                0
              </p>
              <picture>
                <source
                  media="(max-width: 1024px)"
                  srcset="/assets/icons/cart-small-cream.svg"
                />
                <img
                  class="cart-icon"
                  src="/assets/icons/cart-md-cream.svg"
                  alt="Cart icon"
                />
              </picture>
            </button>
          </div>
        )
      }
    </div>
    <div class="secondary-nav">
      {isSecondary && <NavMenu direction={navMenuDirection} />}
    </div>
  </nav>
</header>

<script>
  // @ts-nocheck
  import {
    isMobileViewport,
    openContactMenu,
  } from "../../scripts/mobileMenu.js";

  const CART_STORAGE_KEY = "hart_cart";
  const CART_CHANGE_EVENT = "hart-cart-change";

  const readCartCount = () => {
    try {
      const stored = localStorage.getItem(CART_STORAGE_KEY);
      if (!stored) return 0;

      const cart = JSON.parse(stored);
      let count = 0;
      for (const item of cart) {
        count += item.quantity || 0;
      }
      return count;
    } catch {
      return 0;
    }
  };

  const renderCount = () => {
    const countNodes = document.querySelectorAll("[data-cart-count]");
    const count = String(readCartCount());
    countNodes.forEach((node) => {
      node.textContent = count;
    });
  };

  const initializeCartCount = () => {
    const win = /** @type {any} */ (window);
    win.__hartSyncCartCount = renderCount;
    window.removeEventListener(CART_CHANGE_EVENT, renderCount);
    renderCount();
    window.addEventListener(CART_CHANGE_EVENT, renderCount);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeCartCount, {
      once: true,
    });
  } else {
    initializeCartCount();
  }

  document.addEventListener("astro:page-load", initializeCartCount);
  document.addEventListener("astro:after-swap", initializeCartCount);

  const initializeCartModal = (() => {
    let clickHandler = null;

    return () => {
      const cartButtons = document.querySelectorAll(".cart-icon-wrapper");

      if (clickHandler) {
        cartButtons.forEach((button) => {
          button.removeEventListener("click", clickHandler);
        });
      }

      clickHandler = (event) => {
        event.preventDefault();
        const win = /** @type {any} */ (window);

        if (typeof win.__hartOpenCartModal === "function") {
          win.__hartOpenCartModal();
          return;
        }

        win.__hartPendingCartModal = true;
        window.dispatchEvent(new CustomEvent("open-cart"));
      };

      cartButtons.forEach((button) => {
        button.addEventListener("click", clickHandler);
      });
    };
  })();

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeCartModal, {
      once: true,
    });
  } else {
    initializeCartModal();
  }

  document.addEventListener("astro:page-load", initializeCartModal);
  document.addEventListener("astro:after-swap", initializeCartModal);

  // Mobile menu toggle with handler cleanup and navigation-aware open
  const initializeMobileMenu = (() => {
    let clickHandler = null;
    let closeHandler = null;
    let secondaryNavHandler = null;

    return () => {
      const mobileToggle = document.querySelector(".mobile-toggle");
      const mobileMenu = document.querySelector(".mobile-menu--overlay");
      const closeButton = mobileMenu?.querySelector(".close");
      const secondaryNav = document.querySelector(".secondary-nav");

      // Remove old listeners to prevent accumulation
      if (mobileToggle && clickHandler) {
        mobileToggle.removeEventListener("click", clickHandler);
      }
      if (closeButton && closeHandler) {
        closeButton.removeEventListener("click", closeHandler);
      }
      if (secondaryNav && secondaryNavHandler) {
        secondaryNav.removeEventListener("click", secondaryNavHandler);
      }

      // Create new handlers
      clickHandler = () => {
        mobileMenu?.classList.toggle("active");
      };
      closeHandler = () => {
        mobileMenu?.classList.remove("active");
      };

      secondaryNavHandler = (e) => {
        const target =
          e.target instanceof Element ? e.target.closest("a") : null;
        if (!target) return;

        const href = target.getAttribute("href");
        const targetAttr = target.getAttribute("target");
        if (!href || href.startsWith("http") || targetAttr === "_blank") return;

        try {
          const url = new URL(href, window.location.origin);
          const isMobile = isMobileViewport();

          if (isMobile && url.pathname === "/contact") {
            e.preventDefault();
            openContactMenu();
          }
        } catch {
          // ignore invalid URLs
        }
      };

      // Add new listeners
      if (mobileToggle && mobileMenu) {
        mobileToggle.addEventListener("click", clickHandler);
      }
      if (closeButton && mobileMenu) {
        closeButton.addEventListener("click", closeHandler);
      }
      if (secondaryNav) {
        secondaryNav.addEventListener("click", secondaryNavHandler);
      }
      mobileMenu?.classList.remove("active");
    };
  })();

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeMobileMenu, {
      once: true,
    });
  } else {
    initializeMobileMenu();
  }

  document.addEventListener("astro:page-load", initializeMobileMenu);
  document.addEventListener("astro:after-swap", initializeMobileMenu);
</script>

<style>
  header {
    position: fixed;
    top: 0;
    padding-inline: var(--space-s);
    width: 100svw;
    transition: padding-inline var(--easy);
    background: var(--header-bg);
    z-index: 10;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-xs);
    transition: padding var(--easy);
  }

  nav {
    position: relative;
  }

  .logo {
    width: 79px;
    transition: width 0.3s ease;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-l);
  }

  .secondary-nav {
    position: absolute;
    inset: 100% 0 auto 0;
    display: flex;
    align-items: center;
  }

  .header-menu-wrapper {
    opacity: 0;
    display: none;
  }

  .cart-icon-wrapper {
    display: grid;
    place-content: start center;
    position: relative;
    background: var(--color-charcoal);
    border: none;
    appearance: none;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 100%;
    padding: var(--space-xs);
    cursor: pointer;
    transition:
      width var(--easy),
      height var(--easy);
  }

  .cart-icon-wrapper:hover .cart-icon {
    transform: scale(1.05);
  }

  .cart-icon {
    place-self: start center;
    transition: var(--easy);
    width: 1.125rem;
  }

  .cart-count {
    opacity: 0%;
    position: absolute;
    place-self: center;
    top: 35%;
    z-index: +1;
    color: var(--color-cream);
    transform: scale(0.5);
    transition:
      opacity var(--easy),
      transform var(--easy);
    font-size: var(--text-xs);
  }

  @media (hover: hover) {
    .mobile-toggle:hover {
      cursor: pointer;
    }
  }

  @media screen and (width > 1024px) {
    .mobile-toggle {
      display: none;
    }
    header {
      padding-inline: var(--space-m);
    }
    .header {
      padding-block: var(--space-s);
    }
    .header-actions {
      gap: var(--space-l);
    }

    .header-menu-wrapper {
      display: flex;
      align-items: center;
      opacity: 1;
    }

    .logo {
      width: 100%;
    }

    .cart-icon-wrapper {
      width: 2.635rem;
      height: 2.625rem;
    }

    .cart-icon {
      width: auto;
    }

    .cart-count {
      opacity: 100%;
      transform: scale(1);
    }
  }
</style>
