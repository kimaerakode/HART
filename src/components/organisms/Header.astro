---
import { fade } from "astro:transitions";
import NavMenu from "../molecules/NavMenu.astro";
const {
  color = "cream",
  variant = "primary",
  borderless = false,
} = Astro.props;
const isSecondary = variant === "secondary";
const navMenuDirection = isSecondary ? "column" : "row";

const logoSrc =
  color === "charcoal"
    ? "/assets/brand/hart-logo-primary-charcoal.svg"
    : "/assets/brand/hart-logo-primary-cream.svg";
---

<header class={!isSecondary && !borderless ? "header--primary" : ""}>
  <nav>
    <div
      class="header"
      transition:name="header-row"
      transition:animate={fade({ duration: "0.2s" })}
    >
      <a href="/">
        <img
          class="logo"
          width="100"
          height="39"
          src={logoSrc}
          alt="HART logo"
        /></a
      >
      {
        isSecondary ? (
          <a class="cart-icon-wrapper" href="">
            <p class="cart-count text-xs">10</p>
            <picture>
              <source
                media="(max-width: 1024px)"
                srcset="/assets/icons/cart-small-cream.svg"
              />
              <img
                class="cart-icon"
                src="/assets/icons/cart-md-cream.svg"
                alt="Cart icon"
              />
            </picture>
          </a>
        ) : (
          <div class="header-actions">
            <div class="header-menu-wrapper">
              <NavMenu direction={navMenuDirection} />
            </div>
            <a class="cart-icon-wrapper" href="">
              <p class="cart-count text-xs">10</p>
              <picture>
                <source
                  media="(max-width: 1024px)"
                  srcset="/assets/icons/cart-small-cream.svg"
                />
                <img
                  class="cart-icon"
                  src="/assets/icons/cart-md-cream.svg"
                  alt="Cart icon"
                />
              </picture>
            </a>
          </div>
        )
      }
    </div>
    <div class="secondary-nav">
      {isSecondary && <NavMenu direction={navMenuDirection} />}
    </div>
  </nav>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    padding-inline: var(--space-s);
    width: 100svw;
    transition: padding-inline var(--easy);
    background: var(--header-bg);
    z-index: 10;
  }

  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-xs);
    transition: padding var(--easy);
  }

  nav {
    position: relative;
  }

  .logo {
    width: 79px;
    transition: width 0.3s ease;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-l);
  }

  .secondary-nav {
    position: absolute;
    inset: 100% 0 auto 0;
    display: flex;
    align-items: center;
  }

  .header-menu-wrapper {
    opacity: 0;
    display: none;
  }

  .cart-icon-wrapper {
    position: relative;
    background: var(--color-charcoal);
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 100%;
    padding: var(--space-xs);
    transition:
      width var(--easy),
      height var(--easy);
  }

  .cart-icon-wrapper:hover .cart-icon {
    transform: scale(1.05);
  }

  .cart-icon {
    place-self: start center;
    transition: var(--easy);
    width: 1.125rem;
  }

  .cart-count {
    opacity: 0%;
    position: absolute;
    place-self: center;
    top: 35%;
    z-index: +1;
    color: var(--color-cream);
    transform: scale(0.5);
    transition:
      opacity var(--easy),
      transform var(--easy);
    font-size: var(--text-xs);
  }

  @media screen and (width > 1024px) {
    header {
      padding-inline: var(--space-m);
    }
    .header {
      padding-block: var(--space-s);
    }
    .header-actions {
      gap: var(--space-l);
    }

    .header-menu-wrapper {
      display: flex;
      align-items: center;
      opacity: 1;
    }

    .logo {
      width: 100%;
    }

    .cart-icon-wrapper {
      width: 2.635rem;
      height: 2.625rem;
    }

    .cart-icon {
      width: auto;
    }

    .cart-count {
      opacity: 100%;
      transform: scale(1);
    }
  }
</style>
