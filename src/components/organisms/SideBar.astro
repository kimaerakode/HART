---
import ShopsMenu from "../molecules/ShopsMenu.astro";
import ContactMenu from "../molecules/ContactMenu.astro";
import PreorderMenu from "../molecules/PreorderMenu.astro";
import FAQMenu from "../molecules/FAQMenu.astro";
const { title, sidebarClass = "" } = Astro.props;
---

<div class={`sidebar ${sidebarClass}`}>
  <div class="title-wrapper">
    <h1>{title}</h1>
  </div>

  <div class="content">
    {
      title === "Shops" ? (
        <ShopsMenu />
      ) : title === "Contact" ? (
        <ContactMenu />
      ) : title === "Pre-Order" ? (
        <PreorderMenu />
      ) : title === "FAQ" ? (
        <FAQMenu />
      ) : null
    }
  </div>
</div>

<style>
  .sidebar {
    display: none;
  }
  @media screen and (min-width: 1024px) {
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: var(--space-s);
      width: 14.25rem;
      height: calc(
        100vh - (var(--header-height) + var(--footer-height)) -
          (var(--space-m) * 2)
      );
      background-color: var(--color-cream);
      padding-inline: var(--space-m);
      grid-column: 1;
      border-right: var(--border) var(--color-charcoal);
    }

    .title-wrapper {
      gap: 6px;
      border-bottom: var(--border) var(--color-charcoal);
    }

    .content {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 100%;
    }

    .add-margin {
      margin-block: var(--space-m);
    }
  }
</style>
