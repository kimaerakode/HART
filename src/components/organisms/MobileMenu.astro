---
import NavMenu from "../molecules/NavMenu.astro";
import ContactMenu from "../molecules/ContactMenu.astro";
import InstagramHandle from "../atoms/InstagramHandle.astro";
const { variant = "main", state } = Astro.props;
---

<div
  class={`${state} mobile-menu--overlay`}
  data-mobile-menu-view={variant === "contact" ? "contact" : "main"}
>
  <div class="top-bar">
    <button class="close">
      <img src="/assets/icons/cross-cream.svg" alt="Close menu (X)" /></button
    >
  </div>
  <div class="arrow-bar">
    <button class="arrow-left" type="button" data-mobile-menu-back>
      <img src="/assets/icons/arrow-back-cream.svg" alt="Back" />
    </button>
  </div>

  <div
    class="mobile-menu-views"
    data-menu-view={variant === "contact" ? "contact" : "main"}
  >
    <div
      class="mobile-menu-wrapper mobile-menu-wrapper--main"
      data-menu-panel="main"
    >
      <NavMenu direction="column" parent="mobile" />
    </div>
    <div
      class="mobile-menu-wrapper mobile-menu-wrapper--sub"
      data-menu-panel="contact"
    >
      <ContactMenu />
    </div>
  </div>
  <div class="bottom">
    <InstagramHandle />
    <img
      class="logo"
      src="/assets/brand/hart-logo-handwritten-cream.png"
      alt="Hart logo"
    />
  </div>
</div>

<script>
  // @ts-nocheck
  import {
    isMobileViewport,
    openContactMenu,
    setMobileMenuView,
  } from "../../scripts/mobileMenu.js";
  /** @type {((event: MouseEvent) => void) | null} */
  let linkHandler = null;
  /** @type {((event: MouseEvent) => void) | null} */
  let backButtonHandler = null;

  const initializeMobileMenuView = () => {
    const menu = document.querySelector(".mobile-menu--overlay");
    if (!menu) return;

    const backButton = menu.querySelector("[data-mobile-menu-back]");

    if (linkHandler) {
      menu.removeEventListener("click", linkHandler);
    }
    if (backButton && backButtonHandler) {
      backButton.removeEventListener("click", backButtonHandler);
    }

    linkHandler = (/** @type {MouseEvent} */ event) => {
      const target =
        event.target instanceof Element ? event.target.closest("a") : null;
      if (!target) return;

      const href = target.getAttribute("href");
      const targetAttr = target.getAttribute("target");
      if (!href || href.startsWith("http") || targetAttr === "_blank") return;

      try {
        const url = new URL(href, window.location.origin);
        const inMainPanel = Boolean(target.closest('[data-menu-panel="main"]'));

        if (isMobileViewport() && inMainPanel && url.pathname === "/contact") {
          event.preventDefault();
          openContactMenu();
        }
      } catch {
        // ignore invalid URLs
      }
    };

    menu.addEventListener("click", linkHandler);

    if (backButton) {
      backButtonHandler = () => {
        setMobileMenuView(menu, "main");
      };
      backButton.addEventListener("click", backButtonHandler);
    }

    const win = /** @type {any} */ (window);
    const pending = win.__hartPendingMobileMenu;
    if (pending?.open) {
      setMobileMenuView(menu, "main");
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeMobileMenuView, {
      once: true,
    });
  } else {
    initializeMobileMenuView();
  }

  document.addEventListener("astro:page-load", initializeMobileMenuView);
  document.addEventListener("astro:after-swap", initializeMobileMenuView);
</script>

<style>
  .mobile-menu--overlay {
    background-color: var(--color-charcoal);
    color: var(--color-cream);
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
    display: flex;
    flex-direction: column;
    min-height: 90svh;
    max-width: 90svw;
    inset: 0;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 11;
    transform: translateX(-100%);
    transition: transform var(--easy);
  }

  .mobile-menu--overlay.active {
    transform: translateX(0);
  }

  .close,
  .arrow-left {
    display: flex;
    align-items: center;
  }

  @media (hover: hover) {
    .close:hover {
      cursor: pointer;
    }
  }

  .close img {
    width: var(--space-s);
  }

  .arrow-left img {
    width: var(--space-m);
  }

  .top-bar {
    height: var(--header-height);
  }
  .top-bar,
  .arrow-bar {
    width: 100%;

    border-bottom: var(--border) var(--color-cream);
  }

  .arrow-bar {
    display: none;
  }

  .mobile-menu--overlay[data-mobile-menu-view="contact"] .arrow-bar,
  .mobile-menu--overlay[data-mobile-menu-view="contact"] .arrow-bar {
    display: block;
  }

  .top-bar,
  .arrow-bar,
  .bottom {
    padding: var(--space-s);
  }

  .mobile-menu-views {
    display: grid;
    flex: 1;
  }

  .mobile-menu-wrapper {
    grid-area: 1 / 1;
    display: flex;
    flex-direction: column;
    pointer-events: none;
    opacity: 0;
  }

  .mobile-menu-views[data-menu-view="main"] [data-menu-panel="main"],
  .mobile-menu-views[data-menu-view="contact"] [data-menu-panel="contact"],
  .mobile-menu-views[data-menu-view="contact"] [data-menu-panel="contact"] {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-wrapper--main {
    align-self: start;
  }

  .mobile-menu-wrapper--sub {
    flex-direction: column;
  }

  .bottom {
    display: flex;
    flex: 1;
    justify-content: space-between;
    align-items: end;
    width: 100%;
    font-size: var(--text-s);
  }

  .logo {
    width: 10rem;
  }

  @media screen and (min-width: 1024px) {
    .mobile-menu--overlay {
      display: none;
    }
  }
</style>
