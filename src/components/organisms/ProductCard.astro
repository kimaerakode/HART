---
import ButtonSmall from "../atoms/ButtonSmall.astro";
const { title, price, imgSrc } = Astro.props;
const CardImgSrc = imgSrc ?? `/assets/img/products/${imgSrc}`;
---

<article class="card">
  <div class="button-wrapper">
    <ButtonSmall title="add to cart" color="cream" />
  </div>
  <div class="img-wrapper">
    <img src={CardImgSrc} alt=`${title} image` />
  </div>
  <div class="description">
    <p class="title">{title}</p>
    <p class="price">{price}</p>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 0;
    align-items: start;
    justify-items: stretch;
  }

  p {
    line-height: 120%;
  }

  .img-wrapper {
    /* aspect-ratio: 5 / 6; */
    width: 100%;
    height: auto;
    overflow: clip;
    border-radius: 10px;
    background-color: var(--color-charcoal);
    flex: 0 0 auto;
    aspect-ratio: 5 / 6;
    overflow: hidden;
  }

  img {
    aspect-ratio: 5 / 6;
    object-fit: cover;
    width: 100%;
    height: 100%;
    transition:
      transform var(--slowly),
      opacity var(--slowly);
  }
  .description {
    display: flex;
    justify-content: space-between;

    padding-block-start: 6px;
    padding-inline: 3px;
    flex: 1 1 auto;
    gap: var(--space-s);
    width: 100%;
  }
  .title {
    max-width: 70%;
  }
  .price {
    white-space: nowrap;
    font-size: var(--text-xs);
    margin-top: 1.5px;
  }

  .button-wrapper {
    position: absolute;
    top: var(--space-xs);
    right: var(--space-xs-s);
    z-index: +1;
  }

  @media screen and (min-width: 1024px) {
    .card {
      --columns: 2;
      display: grid;
      grid-template-rows: auto 1fr;
      align-items: start;
      justify-items: stretch;
      height: 100%;
      width: calc(
        (100cqi - (var(--space-l) * (var(--columns) - 1))) / var(--columns)
      );

      @container products (width > 600px) {
        --columns: 4;
      }
      @container products (width > 980px) {
        --columns: 5;
      }

      @container products (width > 1300px) {
        --columns: 6;
      }
    }

    .price {
      font-size: var(--text-s);
    }

    .img-wrapper {
      aspect-ratio: 5 / 6;
      width: 100%;
      align-self: start;
      overflow: hidden;
      grid-row: 1 / 2;
    }

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .description {
      padding-block: var(--space-xs);
      grid-row: 2 / 3;
      min-height: 0;
    }

    .button-wrapper {
      opacity: 0;
      transition: opacity var(--easy);
    }

    .card:hover {
      cursor: pointer;
    }

    .card:hover .button-wrapper {
      opacity: 1;
    }

    .card:hover img {
      transform: scale(1.03);
      opacity: 0.9;
    }
  }
</style>
