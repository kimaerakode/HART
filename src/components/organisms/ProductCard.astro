---
import ButtonSmall from "../atoms/ButtonSmall.astro";
const { title, price, imgSrc, category, favorite, time, description, allergens } =
  Astro.props;
const CardImgSrc = imgSrc;
---

<article
  class="card"
  data-category={category}
  data-favorite={favorite}
  data-title={title}
  data-price={price}
  data-img={CardImgSrc}
  data-time={time}
  data-description={description}
  data-allergens={allergens}
  role="button"
  tabindex="0"
>
  <div class="button-wrapper">
    <div class="hover-btn">
      <ButtonSmall title="add to cart" color="cream" font="graphik caps">
        {time ? <span class="time-label">available from {time}</span> : null}
      </ButtonSmall>
    </div>
  </div>
  <div class="img-wrapper">
    <img src={CardImgSrc} alt={`${title} image`} width="222" height="266" />
  </div>
  <div class="description">
    <p class="title">{title}</p>
    <p class="price">{price}</p>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-items: stretch;
  }

  p {
    line-height: 120%;
  }

  .img-wrapper {
    width: 100%;
    height: auto;
    overflow: clip;
    border-radius: 10px;
    background-color: var(--color-charcoal);
    flex: 0 0 auto;
    aspect-ratio: 5 / 6;
    overflow: hidden;
  }

  img {
    aspect-ratio: 5 / 6;
    object-fit: cover;
    min-width: 100%;
    height: 100%;
    transition:
      transform var(--slowly),
      opacity var(--slowly);
  }
  .description {
    display: flex;
    justify-content: space-between;
    padding-block-start: 6px;
    padding-inline: 3px;
    flex: 1 1 auto;
    gap: var(--space-s);
    width: 100%;
  }
  .title {
    max-width: 70%;
  }
  .price {
    white-space: nowrap;
    font-size: var(--text-xs);
    margin-top: 1.5px;
  }

  .button-wrapper {
    position: absolute;
    top: var(--space-xs);
    right: var(--space-xs);
    z-index: +1;
    display: flex;
    flex-direction: column;
    align-items: end;
    gap: var(--space-xs);
  }

  .hover-btn {
    display: flex;
  }

  .time-label {
    display: block;
    text-transform: none;
    border-top: var(--border-thin) var(--color-charcoal);
    padding-block-start: 3px;
  }

  @media screen and (min-width: 1024px) {
    .price {
      font-size: var(--text-s);
    }

    .img-wrapper {
      aspect-ratio: 5 / 6;
      width: 100%;
      height: auto;
      align-self: start;
      overflow: hidden;
    }

    img {
      aspect-ratio: 5 / 6;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .description {
      padding-block-start: var(--space-xs);
    }

    .hover-btn {
      opacity: 0;
      transition: opacity var(--easy);
    }

    .card:hover {
      cursor: pointer;
    }

    .card:hover .hover-btn {
      opacity: 1;
    }

    .card:hover img {
      transform: scale(1.03);
      opacity: 0.9;
    }
  }
</style>
