---
import PickupSelect from "../molecules/PickupSelect.astro";
---

<div class="pickup-bar">
  <h4 class="text-xs">Pick-up info:</h4>
  <PickupSelect />
</div>

<style>
  @media screen and (max-width: 400px) {
    .pickup-bar {
      gap: var(--space-s) !important;
    }
  }
  @media screen and (max-width: 440px) {
    h4 {
      font-size: var(--text-xxs);
    }
  }

  .pickup-bar {
    display: flex;
    align-items: center;
    gap: var(--space-m);
    padding-inline: var(--space-s);
    padding-block: var(--space-s);
    border-bottom: var(--border) var(--color-charcoal);
    transition: gap var(--easy);
  }

  h4 {
    margin-bottom: 3px;
    white-space: nowrap;
  }

  @media screen and (min-width: 1024px) {
    .pickup-bar {
      display: none;
    }
  }
</style>
