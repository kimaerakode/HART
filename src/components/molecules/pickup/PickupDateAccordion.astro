---
//@ts-nocheck
import Accordion from "../../atoms/Accordion.astro";
import DatePickerTitle from "./DatePickerTitle.jsx";
import DatePickerField from "./DatePickerField.jsx";
import DatePicker from "./DatePicker.jsx";
---

<Accordion
  title="Select date"
  iconSrc="/assets/icons/accordion-arrow.svg"
  iconName="arrow"
  trailingMode="field"
>
  <DatePickerTitle client:load slot="title-content" />
  <DatePickerField client:load slot="trailing" />
  <DatePicker client:load />
</Accordion>
