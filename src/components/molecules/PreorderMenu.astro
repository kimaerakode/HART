---
import PickupSelection from "./pickup/PickupSelection.astro";
---

<div class="menu-wrapper">
  <div class="menu">
    <PickupSelection />
  </div>
  <div class="caption">
    <div class="title-wrapper">
      <h3>
        <a id="preorder-go-checkout" href="/checkout">Go to checkout</a>
      </h3>
    </div>
    <p class="text-s">
      For next day pick ups, PASTRY orders must be placed before 14:00 and
      Bread orders before 24:00
    </p>
  </div>
</div>

<style>
  .menu {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding-top: var(--space-xs);
  }

  .title-wrapper {
    justify-content: space-between;
    align-items: center;
    gap: var(--space-s);
  }
</style>

<script>
  if (typeof window !== "undefined") {
    const link = document.getElementById("preorder-go-checkout");
    link?.addEventListener("click", function (e) {
      try {
        const raw = window.localStorage.getItem("hart.checkoutSelection");
        const sel = raw ? JSON.parse(raw) : null;
        if (!sel || !sel.location || !sel.date || !sel.time) {
          e.preventDefault();
          // Dispatch the global event to show selection warning (Layout mounts the component)
          const event = new CustomEvent("show-selection-warning", {
            detail: {
              onGo: () => (window.location.href = "/preorder"),
              onClose: () => {
                document.dispatchEvent(
                  new CustomEvent("open-preorder-popover", {
                    bubbles: true,
                  }),
                );
              },
            },
          });
          window.dispatchEvent(event);
        }
      } catch (err) {
        // ignore
      }
    });
  }
</script>
