---
import NavArrow from "../atoms/NavArrow.astro";
---

<div class="arrow-bar">
  <NavArrow direction="left" />
  <NavArrow direction="right" />
</div>

<style>
  .arrow-bar {
    display: none;
  }

  @media screen and (min-width: 1024px) {
    .arrow-bar {
      display: block;
      height: fit-content;
      width: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      align-self: flex-end;
      padding-inline: var(--space-m);
    }
  }
</style>
