---
//@ts-nocheck
import Accordion from "../atoms/Accordion.astro";
import DatePickerTitle from "../atoms/DatePickerTitle";
import DatePickerField from "../atoms/DatePickerField";
import DatePicker from "../atoms/DatePicker";
---

<Accordion
  title="Select date"
  iconSrc="/assets/icons/accordion-arrow.svg"
  iconName="arrow"
  trailingMode="field"
>
  <DatePickerTitle client:load slot="title-content" />
  <DatePickerField client:load slot="trailing" />
  <DatePicker client:load />
</Accordion>
