---
import ButtonSmall from "./ButtonSmall.astro";

const { placement = "mobile" } = Astro.props;
---

<div class={`giftcard giftcard--${placement}`}>
  <div class="title-wrapper">
    <h3>Got a gift card?</h3>
  </div>
  <div class="inner">
    <form action="">
      <input type="text" placeholder="Discount code" />
      <input class="btn" type="submit" value="Apply" />
    </form>

    <img src="/assets/brand/flower-illustration.svg" alt="" />
  </div>
</div>

<style>
  .giftcard {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    padding-block: var(--space-s);
  }

  .giftcard--mobile {
    display: flex;
  }

  .giftcard--desktop {
    display: none;
  }

  @media screen and (min-width: 1024px) {
    .giftcard--mobile {
      display: none;
    }

    .giftcard--desktop {
      display: flex;
    }
  }

  .inner {
    display: flex;
    align-items: end;
    width: 100%;
    gap: var(--space-m);
  }

  form {
    display: flex;
    flex-direction: column;

    gap: var(--space-xs);
    width: 100%;
  }

  .btn {
    cursor: pointer;
    display: flex;
    width: fit-content;
    border: var(--border) var(--color-charcoal);
    border-radius: 5px;
    font-family: "Basel Grotesk Mono";
    font-size: var(--text-m);
    padding-inline: var(--space-xs);
    align-self: end;
    transition: opacity var(--easy);
  }

  @media (hover: hover) {
    .btn:hover {
      opacity: 80%;
    }
  }

  img {
    width: 45px;
  }
</style>
