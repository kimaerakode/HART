---
const { count, color } = Astro.props;
---

<button class={`count ${color}`}
  ><img
    src={`/assets/icons/arrow-decrease-${color}.svg`}
    alt="decrease amount (<)"
  />{count}<img
    src="/assets/icons/arrow-increase-charcoal.svg"
    alt="increase amount (>)"
  /></button
>

<style>
  button.count {
    display: flex;
    justify-content: space-between;
    min-width: 4.5rem;
    height: fit-content;
    gap: var(--space-s);
    border: var(--border-thin) var(--color-charcoal);
    border-radius: 5px;
    padding: var(--space-xs-s) var(--space-xs);
  }

  .charcoal {
    color: var(--color-charcoal);
    background-color: var(--color-cream);
    border-color: var(--color-charcoal);
  }

  .cream {
    color: var(--color-cream);
    background-color: var(--color-charcoal);
    border-color: var(--color-cream);
  }
</style>
